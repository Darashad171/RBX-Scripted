local function LoadViewportCharacter()
    task.wait(1)
    for _, v in ipairs(viewport:GetChildren()) do v:Destroy() end
    local char = LocalPlayer.Character
    if not char then return end

    local cam = Instance.new("Camera")
    cam.CFrame = CFrame.new(Vector3.new(0, 3.5, 5.5), Vector3.new(0, 3, 0))
    cam.Parent = viewport
    viewport.CurrentCamera = cam
    viewport.Ambient = Color3.fromRGB(160, 160, 160)
    viewport.LightDirection = Vector3.new(-0.5, -1, -0.5)

    local charClone = char:Clone()
    for _, obj in ipairs(charClone:GetDescendants()) do
        if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("Animator")
        or obj:IsA("AnimationController") or obj:IsA("Sound")
        or obj:IsA("BodyMover") or obj:IsA("ParticleEmitter") then
            obj:Destroy()
        end
    end
    for _, part in ipairs(charClone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = true
            part.CanCollide = false
            part.CastShadow = false
        end
    end
    charClone.Parent = viewport
    local root = charClone:FindFirstChild("HumanoidRootPart")
    if root then
        local origRoot = char:FindFirstChild("HumanoidRootPart")
        if origRoot then
            local offset = origRoot.CFrame:Inverse()
            for _, part in ipairs(charClone:GetDescendants()) do
                if part:IsA("BasePart") then
                    local orig = char:FindFirstChild(part.Name)
                    if orig and orig:IsA("BasePart") then
                        part.CFrame = offset * orig.CFrame
                    end
                end
            end
        end
        root.CFrame = CFrame.new(0, 0, 0)
        local angle = 0
        local conn
        conn = RunService.Heartbeat:Connect(function(dt)
            if not viewport or not viewport.Parent then conn:Disconnect() return end
            angle = angle + dt * 40
            if root and root.Parent then
                root.CFrame = CFrame.new(0, 0, 0) * CFrame.Angles(0, math.rad(angle), 0)
            end
        end)
    end
end
