--       DROPDOWN CONSTRUCTOR
-- ══════════════════════════════════════
local function CreateDropdown(parent, label, options, defaultOpt, callback, _unused)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 48)
    frame.BackgroundColor3 = CONFIG.CardColor
    frame.ClipsDescendants = true
    frame.Parent = parent
    MakeCorner(frame, 10)
    MakeStroke(frame, CONFIG.BorderColor, 1)

    local nameLbl = CreateLabel(frame, label, 12, CONFIG.SubTextColor, CONFIG.SubFont)
    nameLbl.Size = UDim2.new(0.5, 0, 0, 14)
    nameLbl.Position = UDim2.new(0, 14, 0, 8)

    local selectedLbl = CreateLabel(frame, defaultOpt, 13, CONFIG.TextColor, CONFIG.DefaultFont)
    selectedLbl.Size = UDim2.new(0.6, 0, 0, 20)
    selectedLbl.Position = UDim2.new(0, 14, 0, 24)

    local arrow = CreateLabel(frame, "▾", 16, CONFIG.AccentColor, CONFIG.DefaultFont, Enum.TextXAlignment.Right)
    arrow.Size = UDim2.new(0, 30, 0, 30)
    arrow.Position = UDim2.new(1, -40, 0.5, -15)
    RegisterThemeObject(arrow, "TextColor3")

    local isOpen = false

    for i, optText in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.Size = UDim2.new(1, 0, 0, 36)
        optBtn.Position = UDim2.new(0, 0, 0, 48 + (i - 1) * 38)
        optBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 34)
        optBtn.TextColor3 = CONFIG.TextColor
        optBtn.Text = "  " .. optText
        optBtn.TextSize = 13
        optBtn.Font = CONFIG.SubFont
        optBtn.TextXAlignment = Enum.TextXAlignment.Left
        optBtn.AutoButtonColor = false
        optBtn.Parent = frame

        local sep = Instance.new("Frame")
        sep.Size = UDim2.new(1, -20, 0, 1)
        sep.Position = UDim2.new(0, 10, 1, 0)
        sep.BackgroundColor3 = CONFIG.BorderColor
        sep.Parent = optBtn

        optBtn.MouseEnter:Connect(function() Tween(optBtn, { BackgroundColor3 = Color3.fromRGB(40, 40, 50) }, 0.1) end)
        optBtn.MouseLeave:Connect(function() Tween(optBtn, { BackgroundColor3 = Color3.fromRGB(28, 28, 34) }, 0.1) end)
        optBtn.MouseButton1Click:Connect(function()
            PlaySound("Click")
            selectedLbl.Text = optText
            isOpen = false
            Tween(frame, { Size = UDim2.new(1, 0, 0, 48) }, 0.2)
            Tween(arrow, { Rotation = 0 }, 0.2)
            if callback then callback(optText) end
        end)
    end

    local headerBtn = Instance.new("TextButton")
    headerBtn.Size = UDim2.new(1, 0, 0, 48)
    headerBtn.BackgroundTransparency = 1
    headerBtn.Text = ""
    headerBtn.Parent = frame

    headerBtn.MouseButton1Click:Connect(function()
        PlaySound("Click")
        isOpen = not isOpen
        local targetH = isOpen and (48 + #options * 38) or 48
        Tween(frame, { Size = UDim2.new(1, 0, 0, targetH) }, 0.25)
        Tween(arrow, { Rotation = isOpen and 180 or 0 }, 0.25)
    end)
    return frame
end

