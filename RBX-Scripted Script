local SoundEnabled = true
local SoundService = game:GetService("SoundService")

local Sounds = {
    Click  = { id = "rbxassetid://876939830", volume = 0.6,  pitch = 1.2 },
    Hover  = { id = "rbxassetid://876939830", volume = 0.2,  pitch = 2.0 },
    Toggle = { id = "rbxassetid://876939830", volume = 0.5,  pitch = 0.9 },
    Nav    = { id = "rbxassetid://876939830", volume = 0.4,  pitch = 1.6 },
    Open   = { id = "rbxassetid://876939830", volume = 0.6,  pitch = 0.8 },
    Close  = { id = "rbxassetid://876939830", volume = 0.5,  pitch = 0.6 },
}

local function PlaySound(soundType)
    if not SoundEnabled then return end
    local s = Sounds[soundType]
    if not s then return end
    local sound = Instance.new("Sound")
    sound.SoundId = s.id
    sound.Volume = s.volume
    sound.PlaybackSpeed = s.pitch
    sound.Parent = SoundService
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 3)
end

-- ══════════════════════════════════════
--         UTILITY FUNCTIONS
-- ══════════════════════════════════════
local function Tween(obj, props, duration, style, direction)
    local ti = TweenInfo.new(
        duration or 0.25,
        style or Enum.EasingStyle.Quart,
        direction or Enum.EasingDirection.Out
    )
    TweenService:Create(obj, ti, props):Play()
end

local function MakeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 10)
    c.Parent = parent
    return c
end

local function MakeStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or CONFIG.BorderColor
    s.Thickness = thickness or 1.5
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function MakeGradient(parent, colors, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(colors or {
        ColorSequenceKeypoint.new(0, Color3.fromRGB(40, 10, 10)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 18, 20))
    })
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end

local function CreateLabel(parent, text, size, color, font, xAlign)
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Text = text
    lbl.TextSize = size or 14
    lbl.TextColor3 = color or CONFIG.TextColor
    lbl.Font = font or CONFIG.SubFont
    lbl.TextXAlignment = xAlign or Enum.TextXAlignment.Left
    lbl.Parent = parent
    return lbl
end

local function CreateButton(parent, text, size, pos, accent)
    local btn = Instance.new("TextButton")
    btn.Size = size
    btn.Position = pos
    btn.BackgroundColor3 = accent and CONFIG.AccentColor or CONFIG.CardColor
    btn.TextColor3 = CONFIG.TextColor
    btn.Text = text
    btn.TextSize = 13
    btn.Font = CONFIG.DefaultFont
    btn.AutoButtonColor = false
    btn.Parent = parent
    MakeCorner(btn, 8)
    if accent then RegisterThemeObject(btn, "BackgroundColor3")
    else MakeStroke(btn, CONFIG.BorderColor, 1) end
    btn.MouseEnter:Connect(function()
        PlaySound("Hover")
        Tween(btn, { BackgroundColor3 = accent and CONFIG.AccentColor2 or Color3.fromRGB(50, 50, 58) }, 0.15)
    end)
    btn.MouseLeave:Connect(function()
        Tween(btn, { BackgroundColor3 = accent and CONFIG.AccentColor or CONFIG.CardColor }, 0.15)
    end)
    btn.MouseButton1Down:Connect(function()
        PlaySound("Click")
        Tween(btn, { Size = UDim2.new(size.X.Scale, size.X.Offset - 4, size.Y.Scale, size.Y.Offset - 2) }, 0.08)
    end)
    btn.MouseButton1Up:Connect(function()
        Tween(btn, { Size = size }, 0.08)
    end)
    return btn
end

