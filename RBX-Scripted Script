local function ShowNotification(title, message, duration)
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 280, 0, 60)
    notif.Position = UDim2.new(1, 10, 1, -80)
    notif.BackgroundColor3 = CONFIG.CardColor
    notif.ZIndex = 20
    notif.Parent = ScreenGui
    MakeCorner(notif, 10)
    MakeStroke(notif, CONFIG.AccentColor, 2)

    local strip = Instance.new("Frame")
    strip.Size = UDim2.new(0, 4, 1, 0)
    strip.BackgroundColor3 = CONFIG.AccentColor
    strip.ZIndex = 21
    strip.Parent = notif
    MakeCorner(strip, 2)
    RegisterThemeObject(strip, "BackgroundColor3")

    local tl = CreateLabel(notif, title, 13, CONFIG.TextColor, CONFIG.DefaultFont)
    tl.Size = UDim2.new(1, -20, 0, 16)
    tl.Position = UDim2.new(0, 14, 0, 10)
    tl.ZIndex = 21

    local ml = CreateLabel(notif, message, 11, CONFIG.SubTextColor, CONFIG.SubFont)
    ml.Size = UDim2.new(1, -20, 0, 14)
    ml.Position = UDim2.new(0, 14, 0, 30)
    ml.ZIndex = 21

    local progBg = Instance.new("Frame")
    progBg.Size = UDim2.new(1, 0, 0, 2)
    progBg.Position = UDim2.new(0, 0, 1, -2)
    progBg.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    progBg.ZIndex = 21
    progBg.Parent = notif

    local prog = Instance.new("Frame")
    prog.Size = UDim2.new(1, 0, 1, 0)
    prog.BackgroundColor3 = CONFIG.AccentColor
    prog.ZIndex = 22
    prog.Parent = progBg
    RegisterThemeObject(prog, "BackgroundColor3")

    Tween(notif, { Position = UDim2.new(1, -290, 1, -80) }, 0.4, Enum.EasingStyle.Back)
    Tween(prog, { Size = UDim2.new(0, 0, 1, 0) }, duration or 3, Enum.EasingStyle.Linear)
    task.wait(duration or 3)
    Tween(notif, { Position = UDim2.new(1, 10, 1, -80) }, 0.3)
    task.wait(0.35)
    notif:Destroy()
end

