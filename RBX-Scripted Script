--   PAGE FADE TRANSITION
-- ══════════════════════════════════════════════════
local function SwitchPage(name)
    if ActivePage == name then return end

    -- Fade out current page
    if ActivePage and Pages[ActivePage] then
        local current = Pages[ActivePage]
        Tween(current, { GroupTransparency = 1 }, 0.15, Enum.EasingStyle.Quad)
        task.wait(0.15)
        current.Visible = false
    end

    ActivePage = name

    -- Update nav highlight
    for _, btn in ipairs(NavButtons) do
        local isActive = btn.pageName == name
        Tween(btn.frame, {
            BackgroundColor3 = isActive and Color3.fromRGB(50, 12, 12) or Color3.fromRGB(0, 0, 0)
        }, 0.2)
        btn.frame.BackgroundTransparency = isActive and 0 or 1
        Tween(btn.iconLbl, { TextColor3 = isActive and CONFIG.AccentColor or CONFIG.SubTextColor }, 0.2)
        Tween(btn.nameLbl, { TextColor3 = isActive and CONFIG.TextColor or CONFIG.SubTextColor }, 0.2)
        btn.indicator.BackgroundTransparency = isActive and 0 or 1
    end

    -- Fade in new page
    if Pages[name] then
        local newPage = Pages[name]
        newPage.GroupTransparency = 1
        newPage.Visible = true
        Tween(newPage, { GroupTransparency = 0 }, 0.2, Enum.EasingStyle.Quad)
    end
end

