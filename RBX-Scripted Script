local Themes = {
    Crimson = { accent = Color3.fromRGB(200, 30, 30),  accent2 = Color3.fromRGB(255, 60, 60) },
    Neon    = { accent = Color3.fromRGB(0, 200, 255),  accent2 = Color3.fromRGB(80, 230, 255) },
    Gold    = { accent = Color3.fromRGB(220, 170, 20), accent2 = Color3.fromRGB(255, 210, 60) },
    Violet  = { accent = Color3.fromRGB(140, 40, 240), accent2 = Color3.fromRGB(180, 80, 255) },
    Emerald = { accent = Color3.fromRGB(20, 200, 100), accent2 = Color3.fromRGB(60, 240, 130) },
    Rose    = { accent = Color3.fromRGB(230, 50, 120), accent2 = Color3.fromRGB(255, 90, 150) },
}
local CurrentTheme = "Crimson"
local ThemeObjects = {}

local function ApplyTheme(themeName)
    local t = Themes[themeName]
    if not t then return end
    CurrentTheme = themeName
    CONFIG.AccentColor = t.accent
    CONFIG.AccentColor2 = t.accent2
    for _, entry in ipairs(ThemeObjects) do
        pcall(function() entry.obj[entry.prop] = t.accent end)
    end
end

local function RegisterThemeObject(obj, prop)
    table.insert(ThemeObjects, {obj = obj, prop = prop})
end

