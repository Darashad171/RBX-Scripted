local function CreateToggle(parent, label, description, defaultState, callback, _unused)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 56)
    frame.BackgroundColor3 = CONFIG.CardColor
    frame.Parent = parent
    MakeCorner(frame, 10)
    MakeStroke(frame, CONFIG.BorderColor, 1)

    local nameLbl = CreateLabel(frame, label, 13, CONFIG.TextColor, CONFIG.DefaultFont)
    nameLbl.Size = UDim2.new(1, -80, 0, 16)
    nameLbl.Position = UDim2.new(0, 14, 0, 10)

    local descLbl = CreateLabel(frame, description, 11, CONFIG.SubTextColor, CONFIG.SubFont)
    descLbl.Size = UDim2.new(1, -80, 0, 14)
    descLbl.Position = UDim2.new(0, 14, 0, 30)

    local pillBg = Instance.new("Frame")
    pillBg.Size = UDim2.new(0, 44, 0, 24)
    pillBg.Position = UDim2.new(1, -58, 0.5, -12)
    pillBg.BackgroundColor3 = defaultState and CONFIG.AccentColor or Color3.fromRGB(50, 50, 60)
    pillBg.Parent = frame
    MakeCorner(pillBg, 12)
    if defaultState then RegisterThemeObject(pillBg, "BackgroundColor3") end

    local pill = Instance.new("Frame")
    pill.Size = UDim2.new(0, 18, 0, 18)
    pill.Position = defaultState and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9)
    pill.BackgroundColor3 = Color3.new(1, 1, 1)
    pill.Parent = pillBg
    MakeCorner(pill, 9)

    local state = defaultState
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(1, 0, 1, 0)
    toggleBtn.BackgroundTransparency = 1
    toggleBtn.Text = ""
    toggleBtn.Parent = frame

    toggleBtn.MouseButton1Click:Connect(function()
        state = not state
        PlaySound("Toggle")
        Tween(pillBg, { BackgroundColor3 = state and CONFIG.AccentColor or Color3.fromRGB(50, 50, 60) }, 0.2)
        Tween(pill, { Position = state and UDim2.new(1, -21, 0.5, -9) or UDim2.new(0, 3, 0.5, -9) }, 0.2)
        if callback then callback(state) end
    end)
    return frame
end

