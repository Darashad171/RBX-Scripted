--       SLIDER CONSTRUCTOR
-- ══════════════════════════════════════
local function CreateSlider(parent, label, icon, minVal, maxVal, defaultVal, callback, _unused)
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 72)
    sliderFrame.BackgroundColor3 = CONFIG.CardColor
    sliderFrame.Parent = parent
    MakeCorner(sliderFrame, 10)
    MakeStroke(sliderFrame, CONFIG.BorderColor, 1)

    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size = UDim2.new(0, 30, 0, 30)
    iconLbl.Position = UDim2.new(0, 12, 0, 8)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = icon
    iconLbl.TextSize = 22
    iconLbl.Font = CONFIG.DefaultFont
    iconLbl.TextColor3 = CONFIG.AccentColor
    iconLbl.Parent = sliderFrame
    RegisterThemeObject(iconLbl, "TextColor3")

    local nameLbl = CreateLabel(sliderFrame, label, 13, CONFIG.TextColor, CONFIG.DefaultFont)
    nameLbl.Size = UDim2.new(1, -100, 0, 16)
    nameLbl.Position = UDim2.new(0, 48, 0, 10)

    local valDisplay = Instance.new("TextLabel")
    valDisplay.Size = UDim2.new(0, 50, 0, 20)
    valDisplay.Position = UDim2.new(1, -60, 0, 6)
    valDisplay.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
    valDisplay.TextColor3 = CONFIG.AccentColor
    valDisplay.Text = tostring(defaultVal)
    valDisplay.TextSize = 13
    valDisplay.Font = CONFIG.DefaultFont
    valDisplay.Parent = sliderFrame
    MakeCorner(valDisplay, 6)
    RegisterThemeObject(valDisplay, "TextColor3")

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -24, 0, 6)
    track.Position = UDim2.new(0, 12, 0, 48)
    track.BackgroundColor3 = Color3.fromRGB(40, 40, 48)
    track.Parent = sliderFrame
    MakeCorner(track, 3)

    local pct = (defaultVal - minVal) / (maxVal - minVal)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = CONFIG.AccentColor
    fill.Parent = track
    MakeCorner(fill, 3)
    RegisterThemeObject(fill, "BackgroundColor3")

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 14, 0, 14)
    thumb.Position = UDim2.new(pct, -7, 0.5, -7)
    thumb.BackgroundColor3 = Color3.new(1, 1, 1)
    thumb.Parent = track
    MakeCorner(thumb, 7)

    local thumbGlow = Instance.new("ImageLabel")
    thumbGlow.Size = UDim2.new(2, 0, 2, 0)
    thumbGlow.Position = UDim2.new(-0.5, 0, -0.5, 0)
    thumbGlow.BackgroundTransparency = 1
    thumbGlow.Image = "rbxassetid://5028857472"
    thumbGlow.ImageColor3 = CONFIG.AccentColor
    thumbGlow.ImageTransparency = 0.6
    thumbGlow.Parent = thumb
    RegisterThemeObject(thumbGlow, "ImageColor3")

    local dragging = false

    local function updateSlider(input)
        local trackAbsPos = track.AbsolutePosition
        local trackAbsSize = track.AbsoluteSize
        local relX = math.clamp((input.Position.X - trackAbsPos.X) / trackAbsSize.X, 0, 1)
        local value = math.floor(minVal + relX * (maxVal - minVal) + 0.5)
        fill.Size = UDim2.new(relX, 0, 1, 0)
        thumb.Position = UDim2.new(relX, -7, 0.5, -7)
        valDisplay.Text = tostring(value)
        if callback then callback(value) end
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            updateSlider(input)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    return sliderFrame
end

